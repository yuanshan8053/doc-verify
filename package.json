{
  "name": "doc-verify",
  "version": "0.2.0",
  "description": "Technical documentation verification toolkit — verify docs against product console and source code with an exploration-first agent workflow",
  "bin": {
    "doc-verify": "bin/doc-verify.js"
  },
  "scripts": {
    "init": "node bin/doc-verify.js init",
    "install-skills": "node bin/doc-verify.js install",
    "login": "node bin/doc-verify.js login",
    "console": "node bin/doc-verify.js console",
    "validate": "node bin/doc-verify.js validate",
    "doctor": "node bin/doc-verify.js doctor",
    "test": "node --test test/*.js"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1"
  },
  "peerDependencies": {
    "@playwright/cli": "^0.1"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "files": [
    "bin",
    "src",
    "skills",
    "schemas",
    "README.md"
  ]
}
